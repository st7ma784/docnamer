# Copy this file to .env and fill in the values you need.
# Anything left blank can usually be configured later via the web UI.

# ── Auth ──────────────────────────────────────────────────────────────────
# Leave AUTH_PASSWORD blank for local/dev use (no login required).
# Set it for any deployment reachable beyond your own machine.
AUTH_USERNAME=admin
AUTH_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API, e.g.
# https://docnamer.example.com
# Leave blank for local dev (defaults to "*").
ALLOWED_ORIGINS=

# ── IMAP mail server ─────────────────────────────────────────────────────
# Leave blank to configure via the web UI instead (Step 2).
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_MAILBOX=INBOX

# ── LLM ───────────────────────────────────────────────────────────────────
# Defaults match the bundled Ollama service in docker-compose.yml.
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.2

# Characters of document text sent to the LLM per request (guards against
# context-window overflow). Raise if using a model with a larger context.
LLM_MAX_CHARS=24000

# ── Storage ───────────────────────────────────────────────────────────────
# Overridden to /app/data by docker-compose.yml — only needed for bare-metal runs.
# DATA_DIR=./data
